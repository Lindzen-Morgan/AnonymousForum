@model AnonymousForum.Models.Thread

<h1>@Model.Title</h1>

<div>
    <p>@Model.Content</p>
</div>

<hr />

<h2>Replies</h2>

@if (Model.Replies.Any())
{
    <ul>
        @foreach (var reply in Model.Replies)
        {
            <li>
                <p>@reply.Content</p>
                <p>Posted by: @reply.Author</p>
            </li>
        }
    </ul>
}
else
{
    <p>No replies yet.</p>
}

<h2>Post a Reply</h2>

<form asp-action="PostReply" asp-controller="Thread" method="post">
    <div class="form-group">
        <label for="replyContent">Reply Content:</label>
        <textarea class="form-control" id="replyContent" name="content" rows="3" required></textarea>
    </div>
    <button type="submit" class="btn btn-primary">Submit Reply</button>
</form>
